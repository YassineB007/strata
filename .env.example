# -----------------------------------------------------------------------------
# Supabase — JavaScript client (Project Settings → API)
# Use the project URL and either the anon (JWT) key or the publishable default key.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Optional: newer dashboard keys (used if ANON_KEY is unset)
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# -----------------------------------------------------------------------------
# Supabase Auth — Dashboard → Authentication → URL configuration
# Site URL: http://localhost:3000 (or your deployed origin)
# Redirect URLs: http://localhost:3000/auth/callback (add production URL when you deploy)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Prisma (`npm run db:push`, `npm run db:seed`) — Postgres connection string
# Supabase: Settings → Database → URI (direct or session pooler).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres
